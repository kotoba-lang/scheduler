{:paths ["src"]
 :version "0.1.0"
 ;; kotoba-lang/scheduler — durable tick scheduler. Layered on the kotoba-lang
 ;; foundational stdlib; consumes async (bounded ready-queue), time (clock +
 ;; intervals), coll (job shaping). A real consumer of those three libs (M5
 ;; for async/time/coll). No third-party deps; .cljc.
 ;; See ADR-kotoba-lang-foundational-stdlib.md.
 :deps {io.github.kotoba-lang/async {:git/sha "710e342414924910e132272ff0862892a14a4fc6"}
        io.github.kotoba-lang/time   {:git/sha "c5bca3c4f0f40b8a75aa6917213868a5d2e5ac43"}
        io.github.kotoba-lang/coll   {:git/sha "9740cc2dc43a192077d77374b869a37940c801e4"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
